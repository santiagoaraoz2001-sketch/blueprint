# Blueprint Environment Variables
# Copy this file to .env and customize for your setup

# Data directory (default: ~/.specific-labs)
# BLUEPRINT_DATA_DIR=~/.specific-labs

# CORS origins for the backend API (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Vite dev server port
# VITE_PORT=5173

# Backend API target (for Vite proxy in development)
# VITE_API_TARGET=http://127.0.0.1:8000

# Inference server URLs
# OLLAMA_URL=http://localhost:11434
# MLX_URL=http://localhost:8080

# Frontend inference server URLs (must be prefixed with VITE_)
# VITE_OLLAMA_URL=http://localhost:11434
# VITE_MLX_URL=http://localhost:8080
