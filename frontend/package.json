{
  "name": "blueprint",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "config": {
    "forge": "./electron/forge.config.cjs"
  },
  "scripts": {
    "codegen": "cd .. && python3 scripts/generate_block_registry.py && python3 scripts/generate_port_compat.py",
    "codegen:watch": "cd .. && python3 scripts/watch_block_registry.py",
    "generate:api": "cd .. && python3 scripts/generate_api_types.py && cd frontend && npx openapi-typescript src/api/schema.json -o src/api/generated-types.ts",
    "generate:compat": "cd .. && python3 scripts/generate_compat.py",
    "prebuild": "npm run codegen && npm run generate:compat && npm run generate:api && cd .. && python3 scripts/normalize_blocks.py --check",
    "dev": "npm run codegen && npm run generate:api && concurrently \"npm run codegen:watch\" \"vite\"",
    "lint": "eslint src/",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-forge make",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.2",
    "@xyflow/react": "^12.6.0",
    "dagre": "^0.8.5",
    "framer-motion": "^12.6.0",
    "immer": "^11.1.4",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.5.2",
    "recharts": "^2.15.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.1.1",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.3"
  }
}
