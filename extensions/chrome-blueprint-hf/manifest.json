{
  "manifest_version": 3,
  "name": "Blueprint - HuggingFace Dataset Importer",
  "version": "0.3.1",
  "description": "Send HuggingFace datasets to your local Blueprint ML workbench",
  "permissions": ["activeTab"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://huggingface.co/datasets/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
